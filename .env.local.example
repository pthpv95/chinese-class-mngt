# Database (local: docker-compose postgres, prod: Supabase / Neon / RDS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elearning
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/elearning

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run-openssl-rand-base64-32

# Storage — S3-compatible
# Local (MinIO via docker-compose):
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=audio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Production (AWS S3) — remove S3_ENDPOINT, set real credentials:
# S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=ap-southeast-1
